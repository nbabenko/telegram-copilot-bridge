TELEGRAM_BOT_TOKEN=1234567890:replace_me
BOT_USERNAME=your_bot_username_without_at
ALLOWED_USER_IDS=123456789
REPO_PATH=/absolute/path/to/target/repository
UPLOAD_DIR=/absolute/path/to/target/repository/.telegram-copilot-uploads
COPILOT_BIN=/usr/bin/copilot
COPILOT_TIMEOUT=1200
TELEGRAM_TIMEOUT=30
OBJECT_STORAGE_ENDPOINT=storage.example.com
OBJECT_STORAGE_BUCKET=example-bucket
OBJECT_STORAGE_ACCESS_KEY_ID=replace_me
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace_me
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PUBLIC_BASE_URL=https://media.example.com
OBJECT_STORAGE_PREFIX=uploads